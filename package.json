{
	"name": "musicview",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.10.0",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --deny-warnings . --fix",
		"fmt": "oxfmt --write src/",
		"fmt:check": "oxfmt --check src/",
		"typecheck": "tsc --noEmit",
		"deploy": "opennextjs-cloudflare && wrangler deploy",
		"preview": "opennextjs-cloudflare && wrangler dev",
		"cf-typegen": "wrangler types",
		"cf-typegen:check": "wrangler types --check"
	},
	"dependencies": {
		"next": "16.2.10",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@opennextjs/cloudflare": "1.20.1",
		"@tailwindcss/postcss": "4.3.1",
		"@types/node": "24.13.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"oxfmt": "0.58.0",
		"oxlint": "1.63.0",
		"oxlint-tsgolint": "0.24.0",
		"tailwindcss": "4.3.1",
		"typescript": "6.0.3",
		"wrangler": "4.105.0"
	}
}
